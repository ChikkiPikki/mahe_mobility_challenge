# ── Local VLM (vLLM server on host) ──────────────────────────
LOCAL_VLM_ENABLED=true
LOCAL_VLM_BASE_URL=http://localhost:8000/v1
LOCAL_VLM_MODEL=Qwen/Qwen2.5-VL-3B-Instruct
LOCAL_VLM_API_KEY=not-needed

# ── Cloud: NVIDIA NIM (optional fallback) ────────────────────
# NVIDIA_API_KEY=nvapi-xxxxxxxx

# ── Cloud: OpenRouter (optional fallback) ────────────────────
# OPENROUTER_API_KEY=sk-or-xxxxxxxx
